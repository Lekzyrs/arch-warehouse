{
  "title": "product-service",
  "uid": "product-svc",
  "schemaVersion": 36,
  "version": 1,
  "editable": true,
  "tags": ["archfinal", "product-service"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cache requests/sec by outcome",
      "datasource": {
        "type": "prometheus",
        "name": "Prometheus"
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "rate(cache_requests_total[1m])",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache hit ratio (1m)",
      "datasource": {
        "type": "prometheus",
        "name": "Prometheus"
      },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(cache_requests_total{result=\"hit\"}[1m])) / sum(rate(cache_requests_total[1m]))",
          "legendFormat": "ratio",
          "refId": "A"
        }
      ]
    }
  ]
}
