{
  "title": "stock-service",
  "uid": "stock-svc",
  "schemaVersion": 36,
  "version": 1,
  "editable": true,
  "tags": ["archfinal", "stock-service"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Stock commands/sec by type",
      "datasource": {
        "type": "prometheus",
        "name": "Prometheus"
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "rate(stock_commands_total[1m])",
          "legendFormat": "{{command_type}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Projection lag (seconds)",
      "datasource": {
        "type": "prometheus",
        "name": "Prometheus"
      },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "projection_lag_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Events published total",
      "datasource": {
        "type": "prometheus",
        "name": "Prometheus"
      },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(stock_events_published_total)",
          "legendFormat": "published",
          "refId": "A"
        }
      ]
    }
  ]
}
