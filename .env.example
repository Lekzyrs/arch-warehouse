# Source: archapp-ts lab4 docker-compose env blocks (parameterized for archfinal).
# INFRA-04: all service config comes only from environment variables.
# Copy to .env (git-ignored) and adjust if needed; defaults work as-is.

# Postgres
POSTGRES_USER=archuser
POSTGRES_PASSWORD=archpass

# Per-service DB names (injected per-service in docker-compose.yml)
PRODUCT_DB_NAME=product_db
STOCK_DB_NAME=stock_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Service ports (single source of truth for docker-compose port mappings
# and per-service SERVER_PORT injection)
PRODUCT_SERVICE_PORT=8080
STOCK_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
